# Production Environment Configuration
# Copy this file to .env on your production server and update all values

# CRITICAL: Set to production
ENVIRONMENT=production

# CRITICAL: Generate a secure key with: python -c "import secrets; print(secrets.token_hex(32))"
# NEVER use the default key in production!
SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_KEY_64_CHARS

# JWT Configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database - Use PostgreSQL in production
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://mustian_user:REPLACE_WITH_DB_PASSWORD@localhost:5432/mustian_prod

# Face Recognition
FACE_CONFIDENCE_THRESHOLD=0.7
USE_SIMPLE_FACE_RECOGNITION=True

# Attendance Window (minutes)
ATTENDANCE_WINDOW_MINUTES=30

# Upload directory
UPLOAD_DIR=/var/www/mustian/uploads/faces

# CORS - Replace with your actual production domains
CORS_ORIGINS=["https://yourdomain.com", "https://www.yourdomain.com"]

# Optional: Sentry for error tracking
# SENTRY_DSN=https://your-sentry-dsn

# Optional: Redis for rate limiting (recommended for production)
# REDIS_URL=redis://localhost:6379/0
