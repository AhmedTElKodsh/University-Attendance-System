# Environment variables for Mustian Face MVP Backend
# Copy this file to .env and update the values

# Database
DATABASE_URL=sqlite:///./mustian_face.db

# JWT - REQUIRED: Generate with: openssl rand -hex 32
SECRET_KEY=your-secure-random-key-here-min-32-chars-CHANGE-THIS

# Environment (development or production)
ENVIRONMENT=development

# JWT Algorithm
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Face Recognition (COMMITTED: Simple mode - no dlib)
FACE_CONFIDENCE_THRESHOLD=0.7
USE_SIMPLE_FACE_RECOGNITION=True

# Attendance Window (minutes)
ATTENDANCE_WINDOW_MINUTES=30

# Upload directory
UPLOAD_DIR=uploads/faces

# CORS - specify exact frontend origins (comma-separated)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:80", "http://localhost"]